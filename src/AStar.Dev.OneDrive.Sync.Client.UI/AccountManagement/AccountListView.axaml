<UserControl
    x:Class="AStar.Dev.OneDrive.Sync.Client.UI.AccountManagement.AccountListView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:AStar.Dev.OneDrive.Sync.Client.UI.AccountManagement"
    x:DataType="vm:AccountListViewModel">

    <StackPanel Spacing="8" Margin="8">

        <TextBlock Text="{DynamicResource Accounts_Title}"
                   FontWeight="Bold"
                   FontSize="16" />

        <ListBox ItemsSource="{Binding Accounts}"
                 SelectedItem="{Binding SelectedAccount}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:AccountInfo">
                    <Border Padding="8" Margin="0,4"
                            Background="{DynamicResource CardBackground}"
                            CornerRadius="4">
                        <StackPanel>
                            <TextBlock Text="{Binding Email}" />
                            <TextBlock Text="{Binding StorageUsed}" FontSize="11" />
                            <TextBlock Text="{Binding LocalSyncRootPath}" FontSize="11" />

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="{DynamicResource Btn_ManageAccount}"
                                    Command="{Binding $parent[UserControl].DataContext.ManageAccountCommand}"
                                    CommandParameter="{Binding}" />
                                <Button Content="{DynamicResource Btn_Logout}"
                                    Command="{Binding $parent[UserControl].DataContext.RemoveAccountCommand}"
                                    CommandParameter="{Binding}" />
                                </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="{DynamicResource Btn_AddAccount}"
                Command="{Binding AddAccountCommand}" />

    </StackPanel>
</UserControl>
