<UserControl
    x:Class="AStar.Dev.OneDrive.Sync.Client.UI.Layouts.DashboardLayoutView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:home="using:AStar.Dev.OneDrive.Sync.Client.UI.Home"
    xmlns:account="using:AStar.Dev.OneDrive.Sync.Client.UI.AccountManagement"
    xmlns:sync="using:AStar.Dev.OneDrive.Sync.Client.UI.SyncStatus"
    x:DataType="home:MainWindowViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Top App Bar -->
        <Border Background="{DynamicResource AppBarBackground}" Height="48">
            <DockPanel>
                <Button Content="☰" Width="48" />
                <TextBlock Text="{DynamicResource App_Title}" 
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <DockPanel DockPanel.Dock="Right">
                    <ComboBox Width="120"
                              ItemsSource="{Binding Settings.AvailableThemes}"
                              SelectedItem="{Binding Settings.SelectedTheme}" />
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*">

            <!-- Left Drawer -->
            <StackPanel Width="220" Background="{DynamicResource DrawerBackground}">
                <Button Content="{DynamicResource Menu_File}" />
                <Button Content="{DynamicResource Account_Email}" />
                <Button Content="{DynamicResource Sync_Activity}" />
                <Button Content="{DynamicResource Menu_UserSettings}" Command="{Binding OpenUserSettingsCommand}" />
                <Button Content="{DynamicResource Menu_AppSettings}" Command="{Binding OpenAppSettingsCommand}" />
            </StackPanel>

            <!-- Dashboard -->
            <ScrollViewer Grid.Column="1" Padding="16">
                <StackPanel Spacing="16">

                    <!-- Account Cards -->
                    <account:AccountListView DataContext="{Binding Accounts}" />

                    <!-- Add Account Card -->
                    <Border Background="{DynamicResource CardBackground}"
                            Padding="20"
                            CornerRadius="8">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource Dashboard_AddAccount}" />
                            <Button Content="+" Width="48" Height="48" />
                        </StackPanel>
                    </Border>

                    <!-- Sync Panel -->
                    <sync:SyncStatusView DataContext="{Binding Sync}" />

                    <Border Background="{DynamicResource CardBackground}" Padding="16" CornerRadius="8">
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Column="0" Text="Linked Accounts" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Selected Account" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="Sync Progress" FontWeight="SemiBold" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LinkedAccountCount}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedAccountEmail}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SyncProgressMetric, StringFormat={}{0}%}" />
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Grid>
</UserControl>
