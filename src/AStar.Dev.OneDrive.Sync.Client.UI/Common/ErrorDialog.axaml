<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:common="clr-namespace:AStar.Dev.OneDrive.Sync.Client.UI.Common"
        x:Class="AStar.Dev.OneDrive.Sync.Client.UI.Common.ErrorDialog"
        x:DataType="common:ErrorDialogViewModel"
        Title="{Binding Title}"
        Width="500"
        Height="300"
        MinWidth="400"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </Window.Styles>

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <!-- Header with icon and title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="⚠️" FontSize="32" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Error message -->
        <Border Grid.Row="1" 
                BorderBrush="{DynamicResource SystemAccentColor}" 
                BorderThickness="1" 
                CornerRadius="5"
                Padding="10"
                Background="{DynamicResource SystemAltLowColor}">
            <ScrollViewer>
                <TextBlock Text="{Binding Message}" 
                          TextWrapping="Wrap" 
                          VerticalAlignment="Top"/>
            </ScrollViewer>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="2" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right" 
                   Margin="0,15,0,0">
            <Button Content="{DynamicResource Btn_OK}" 
                    Click="OnOkClick"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
